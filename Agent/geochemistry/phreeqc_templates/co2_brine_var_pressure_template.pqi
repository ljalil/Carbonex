DATABASE __DATABASE__

SOLUTION 1
	temperature	__TEMPERATURE__
	units	mol/kgw
	Na	__NA__
	Cl	__CL__
	Ca	__CA__
	Mg	__MG__
	K	__K__
	S(6)	__SO4__

GAS_PHASE 1
	-fixed_volume
	CO2(g)	0
	H2O(g)	0

REACTION 1
	CO2 1;	  0 100*0.5

INCREMENTAL_REACTIONS true

SELECTED_OUTPUT
	-file __OUTPUT_FILE__
	-totals	C(4)
	-solution True
	-gases	CO2(g)
	-saturation_indices CO2(g)
END
